# ===== 同学 App 服务器配置 =====

# 服务器端口
PORT=3001

# JWT 密钥（生产环境请改为随机字符串）
JWT_SECRET=tongxue-app-secret-key-2026

# 自身地址（用于部分 OAuth 回调验证）
SELF_URL=http://localhost:3001

# ===== 微信登录（可选） =====
# 在 https://open.weixin.qq.com 注册应用获取
WECHAT_APP_ID=
WECHAT_APP_SECRET=

# ===== QQ 登录（可选） =====
# 在 https://connect.qq.com 注册应用获取
QQ_APP_ID=
QQ_APP_SECRET=

# ===== 数据库路径（默认 ./data/tongxue.db） =====
DB_PATH=./data/tongxue.db
