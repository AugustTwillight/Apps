# ===== Supabase（必需） =====
# 注册: https://supabase.com → New project
# 获取: Settings → API → Project URL + anon public key
SUPABASE_URL=你的项目URL
SUPABASE_KEY=你的anon_key

# ===== 服务器 =====
PORT=3001
JWT_SECRET=改成随机的密钥字符串

# ===== 微信登录（可选） =====
# 注册: https://open.weixin.qq.com → 移动应用
WECHAT_APP_ID=
WECHAT_APP_SECRET=

# ===== QQ 登录（可选） =====
# 注册: https://connect.qq.com → 创建应用
QQ_APP_ID=
QQ_APP_SECRET=

# ===== 短信（可选，二选一） =====
# 方案A: Twilio（国际）
# 注册: https://twilio.com → 获取 Account SID + Auth Token + 手机号
TWILIO_SID=
TWILIO_TOKEN=
TWILIO_PHONE=

# 方案B: 阿里云短信（国内）
# 注册: https://dysms.aliyun.com → 获取 AccessKey
ALIYUN_ACCESS_KEY_ID=
ALIYUN_ACCESS_KEY_SECRET=
ALIYUN_SMS_SIGN=同学
ALIYUN_SMS_TEMPLATE=SMS_xxxxx
